# MuteMe Button Control - Example Configuration File
# Copy this file to ~/.config/muteme/muteme.toml or /etc/muteme/muteme.toml
# Or use it with: uv run muteme-btn-control --config /path/to/muteme.toml

# Device configuration
[device]
# USB Vendor ID for MuteMe device (default: 0x20A0)
vid = 8352  # 0x20A0 in decimal
# USB Product ID for MuteMe device (default: 0x42DA)
pid = 17114  # 0x42DA in decimal
# Device connection timeout in seconds (default: 5.0, range: 0.1-60.0)
timeout = 5.0

# Audio backend configuration
[audio]
# Audio backend to use (default: "pulseaudio")
backend = "pulseaudio"
# Specific PulseAudio source name to control (optional, None = use default microphone input)
# source_name = null
# Audio state polling interval in seconds (default: 0.1, range: 0.01-1.0)
poll_interval = 0.1

# Operating mode configuration
[mode]
# Default button mode: "normal" preserves mute toggle behavior, "ptt" starts in hold-to-talk mode
default = "normal"
# Mode switch gesture: "double_tap_hold" keeps the original gesture;
# "triple_tap" enables three quick taps as the switch gesture.
switch_gesture = "double_tap_hold"
# Used when switch_gesture = "double_tap_hold": maximum time between taps in
# the double-tap portion and how long to hold the second tap before switching.
double_tap_timeout_ms = 300
switch_hold_threshold_ms = 800
# Used when switch_gesture = "triple_tap": tune these from real button logs.
# triple_tap_count: number of quick taps required to switch modes.
triple_tap_count = 3
# triple_tap_window_ms: max time from first press to final release.
triple_tap_window_ms = 650
# tap_max_duration_ms: max individual press duration to count as a quick tap.
tap_max_duration_ms = 140
# inter_tap_timeout_ms: wait after a quick tap before committing single-tap behavior.
inter_tap_timeout_ms = 275
# ptt_hold_threshold_ms: hold duration before PTT mode emits F19 down.
ptt_hold_threshold_ms = 120
# Minimum time between press events to ignore bounce
debounce_time_ms = 10

# Push-to-talk mode configuration
[ptt]
# Synthetic key emitted while the button is held in PTT mode
key = "f19"
# F19 emitter backend: "ydotool" uses a stable virtual-keyboard path that most
# desktop shortcut listeners can observe; "evdev" creates a dedicated uinput
# device for lower-level experiments and may require target apps to restart.
emitter_backend = "ydotool"
# LED color when PTT mode is idle
idle_color = "blue"
# LED color while PTT mode is actively held
active_color = "yellow"

# Logging configuration
[logging]
# Minimum log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
level = "INFO"
# Log output format: "text" for human-readable, "json" for machine parsing (default: "text")
format = "text"
# Log file path (optional, None = stdout)
# file_path = null
# Maximum log file size in bytes (default: 10485760 = 10MB)
max_file_size = 10485760
# Number of backup log files to keep (default: 5, range: 1-20)
backup_count = 5

# Application settings
# Run in daemon mode (default: false)
daemon = false
